# Obol Protocol — Frontend Environment Variables
# Copy this file to .env.local. The defaults below are the LIVE testnet
# deployment (see deployments/testnet.json), so the app works out of the box.

# Soroban RPC + network
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_STELLAR_EXPLORER=https://stellar.expert/explorer/testnet
# Public Horizon endpoint (used to read the latest ledger close time for epoch)
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed contract IDs (Stellar testnet)
NEXT_PUBLIC_LIVENESS_REGISTRY_ID=CDQKTII66Z2BOMXOUU3WHGACAEM4XIUPLFORG5MZEKCVQSB6FMTSXGME
NEXT_PUBLIC_VAULT_CONTROLLER_ID=CDQL4QEZN7QWMC3YTPNGI52IAVSXGNWAMCJD7UGHNFOOKONAI6T5WKOS
NEXT_PUBLIC_OBOL_VERIFIER_ID=CBE4ACZCQTXTPGJVNDAEKSYZLUVJMUMUVMZCMDXSIE3EB67RTSRSKFQ6
NEXT_PUBLIC_KEEPER_REGISTRY_ID=CCKEYJKGNNC475ELXZ56BT2A6WXWT3G32YG2KFDP2BLELHQ437F2LXMA
NEXT_PUBLIC_MOCK_TOKEN_ID=CDEARWWPX4653XD27ZVDQ7UBNNSH36RSUGVNOR3GVYTMXUD5GWCOKCCQ

# Read-only source account used only to simulate view calls (any funded account works).
# Defaults to the deployer address from the testnet deployment.
NEXT_PUBLIC_STELLAR_READ_SOURCE=GCF2TS44FELZGSFXG57OY6LPMOJOUL34SCKCY6OC52X7U5G2YAZZU5F6
